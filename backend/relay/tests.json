{
  "tests": [
    {
      "name": "Create session",
      "method": "POST",
      "path": "/",
      "body": {"action": "create"},
      "expectedStatus": 200,
      "expectedBody": {"pin": "string", "session_id": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Connect with wrong PIN",
      "method": "POST",
      "path": "/",
      "body": {"action": "connect", "pin": "000000"},
      "expectedStatus": 404,
      "bodyMatcher": "partial"
    },
    {
      "name": "Status not found",
      "method": "GET",
      "path": "/?action=status&session_id=notexist",
      "expectedStatus": 404,
      "bodyMatcher": "partial"
    }
  ]
}
